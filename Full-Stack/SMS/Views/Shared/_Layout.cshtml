<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SMS</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>
<body class="h-full flex flex-col bg-gray-50">
    <!-- Navigation -->
    <header class="bg-white shadow-sm">
        <nav class="container mx-auto px-4 py-4">
            <div class="flex items-center justify-between">
                <!-- Logo/Brand -->
                <a asp-area="" asp-controller="Home" asp-action="Index" 
                   class="text-2xl font-bold text-indigo-600 hover:text-indigo-700 transition-colors">
                    🎓 SMS
                </a>
                
                <!-- Mobile Menu Button -->
                <button id="mobile-menu-button" type="button" 
                        class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-700 hover:text-indigo-600 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                
                <!-- Desktop Menu -->
                <ul class="hidden md:flex space-x-1">
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Index" 
                           class="px-4 py-2 rounded-lg text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition-all duration-200 font-medium">
                            🏠 Home
                        </a>
                    </li>
                    <li>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy" 
                           class="px-4 py-2 rounded-lg text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition-all duration-200 font-medium">
                            🔒 Privacy
                        </a>
                    </li>
                </ul>
            </div>
            
            <!-- Mobile Menu -->
            <div id="mobile-menu" class="hidden md:hidden mt-4 space-y-2">
                <a asp-area="" asp-controller="Home" asp-action="Index" 
                   class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition-all duration-200 font-medium">
                    🏠 Home
                </a>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" 
                   class="block px-4 py-2 rounded-lg text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition-all duration-200 font-medium">
                    🔒 Privacy
                </a>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-grow container mx-auto px-4 py-8">
        <div class="bg-white rounded-lg shadow-md p-6">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300 mt-12">
        <div class="container mx-auto px-4 py-6">
            <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
                <div class="text-center md:text-left">
                    <p class="text-sm">
                        &copy; 2026 <span class="font-semibold text-white">School Management System</span> - Tüm hakları saklıdır
                    </p>
                </div>
                <div class="flex space-x-6">
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" 
                       class="text-sm hover:text-white transition-colors duration-200">
                        Gizlilik Politikası
                    </a>
                    <a href="#" class="text-sm hover:text-white transition-colors duration-200">
                        İletişim
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Mobile Menu Toggle Script -->
    <script>
        document.getElementById('mobile-menu-button')?.addEventListener('click', function() {
            const menu = document.getElementById('mobile-menu');
            menu.classList.toggle('hidden');
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
